# ══════════════════════════════════════════════════════════════════
# 综合秘书机器人配置文件
# 使用方法：cp .env.example .env，然后填写你的密钥
# Docker 部署：只需维护这一个文件
# 本地部署：也可继续使用 config.py
# ══════════════════════════════════════════════════════════════════

# ── 飞书配置（必填）────────────────────────────────────────────────
# 运行以下命令自动获取（Docker 模式）：
#   docker exec -it secretary-bot python3 feishu_setup.py
# 或本地模式：
#   python3 feishu_setup.py
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_OPEN_ID=                         # 扫码后自动填入

# ── Alpha Vantage（可选，用于宏观指标/汇率查询）──────────────────
# 免费申请：https://www.alphavantage.co/support/#api-key
# 免费版限制：25 次/天，宏观指标查询约消耗 4 次
ALPHA_VANTAGE_API_KEY=

# ── Telegram（可选，次要平台）──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 启用平台（逗号分隔）────────────────────────────────────────────
# 可选值：feishu, telegram（同时启用：feishu,telegram）
ENABLED_PLATFORMS=feishu

# ── 推送时间默认值（可在飞书内通过"新建定制"修改）────────────────
MORNING_REPORT_HOUR=9
MORNING_REPORT_MINUTE=0
DAILY_DIGEST_HOUR=15
DAILY_DIGEST_MINUTE=30
PRICE_ALERT_INTERVAL_MINUTES=5

# ── 日志 ───────────────────────────────────────────────────────────
# Docker 模式建议写到 logs/ 目录（已挂载为 volume）
LOG_LEVEL=INFO
LOG_FILE=logs/secretary.log